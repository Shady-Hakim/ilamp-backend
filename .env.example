APP_NAME="iLamp Backend"
APP_ENV=local
APP_KEY=
# IMPORTANT: must be false in production — exposes stack traces and env vars.
APP_DEBUG=false
APP_URL=https://ilampagency.com

# TEMPORARY: token for the /__run-migrations route. Generate a strong random value.
# Remove this variable (and the route/controller) once migrations have been run.
MIGRATION_TOKEN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
# Set to true in production to encrypt session data at rest.
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to true in production (HTTPS only). Leave false for local HTTP development.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@ilampagency.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
ADMIN_NAME="iLamp Admin"
ADMIN_EMAIL=admin@ilampagency.com
ADMIN_PASSWORD=changeme123

VITE_APP_NAME="${APP_NAME}"
